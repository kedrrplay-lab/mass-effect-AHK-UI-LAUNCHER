{
  "name": "me-launcher",
  "version": "0.2.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "com.k3nz0iq.melauncher",
    "productName": "Mass Effect Launcher",
    "asar": true,
    "compression": "maximum",
    "npmRebuild": false,
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "ui/**/*"
    ],
    "extraResources": [
      {
        "from": "launcher.exe",
        "to": "../launcher.exe"
      },
      {
        "from": "MassEffectLauncher.ini",
        "to": "../MassEffectLauncher.ini"
      }
    ],
    "win": {
      "target": "portable",
      "icon": "ui/icon.ico"
    }
  },
  "dependencies": {
    "ini": "^6.0.0"
  }
}

{
  "name": "me-launcher",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.me.launcher",
    "productName": "MELE Launcher",

    "asar": true,
    "compression": "maximum",

    "directories": {
      "output": "dist"
    },

    "files": [
      "main.js",
      "preload.js",
      "ui/**/*",
      "icon.png"
    ],

    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },

    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}